[run]
source = .
omit =
    # Management commands — one-time data setup scripts
    */management/commands/*.py
    # Migrations — auto-generated
    */migrations/*.py
    # Test files themselves
    tests/*
    # Config and entry points
    manage.py
    examproject/asgi.py
    examproject/wsgi.py
    # One-off scripts at project root
    physics_themes_topics.py
    test_email.py
    # Heavy admin/teacher tooling — DOCX parser, CSV uploader, AI generator
    teacher/views.py
    # Catalog API views (React test builder backend) — tested via frontend
    catalog/views.py
    catalog/views_savedtest.py
    # Utility files not yet tested
    catalog/subscription_utils.py
    catalog/templatetags/feature_tags.py
    # Empty placeholder files
    */tests.py
    # Health dashboard — staff-only views, no unit test value
    teacher/health_views.py
    teacher/health_urls.py
    # Service wrappers — external APIs mocked in integration tests (pending)
    services/email_service.py
    services/payment_service.py
    services/ai_service.py
    # Payment views — Paystack integration tests pending
    payments/views.py
    # URL configs and sitemaps — no logic to test
    */urls.py
    Users/sitemaps.py
    # Uncovered catalog modules — to be addressed in future test sprints
    catalog/cache_utils.py
    catalog/context_processors.py
    catalog/feature_flags.py
    catalog/note_pdf_parser.py
    catalog/permissions.py
    catalog/serializers.py
    catalog/serializers_savedtest.py
    catalog/subscription_access.py
    # Practice views — integration tested via CBT session tests
    practice/views.py
    practice/past_paper_views.py
    practice/templatetags/question_filters.py
    # Frontend and other thin views
    frontend/views.py
    Users/views.py