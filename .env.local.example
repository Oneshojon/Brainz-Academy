SECRET_KEY=local-dev-secret-key-not-for-production-changeme123
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email prints to terminal — no Brevo needed locally
# (settings.py already falls back to console backend when this key is absent)
# ANYMAIL_BREVO_API_KEY=

# Paystack — use TEST keys
PAYSTACK_SECRET_KEY=sk_test_your_test_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_test_key_here

# Anthropic — leave blank to disable AI features locally
ANTHROPIC_API_KEY=

